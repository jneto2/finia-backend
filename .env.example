# ─────────────────────────────────────────────
# FINIA BACKEND — Variáveis de Ambiente
# ─────────────────────────────────────────────
# Copie este arquivo para .env e preencha os valores.
# NUNCA suba o arquivo .env para o GitHub.

# Anthropic (Claude AI)
# Obtenha em: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXX

# Pluggy (Open Finance Brasil)
# Cadastre-se em: https://dashboard.pluggy.ai
# Plano gratuito disponível para desenvolvimento
PLUGGY_CLIENT_ID=seu-client-id-aqui
PLUGGY_CLIENT_SECRET=seu-client-secret-aqui

# Segurança: chave secreta para assinar tokens internos (gere uma aleatória)
# Exemplo para gerar: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-aleatoria-segura

# Ambiente: "development" ou "production"
ENVIRONMENT=development
